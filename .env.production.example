DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_COMMAND_PREFIX=!

# Comma-separated list of channel names where every non-prefixed message
# is treated as directed at Shrimpicus (no @-mention required).
ASSISTANT_CHANNELS=general

# Database - Production uses PostgreSQL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://shrimpicus:your_password_here@localhost:5432/shrimpicus
# Fallback SQLite path (used if DATABASE_URL is not set)
DB_PATH=./data/shrimpicus.db

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# LLM Provider: "ollama" (local) or "groq" (hosted)
# Use "groq" for faster, free API-based inference (saves RAM)
LLM_PROVIDER=groq

# Groq API (only needed if LLM_PROVIDER=groq)
# Get free API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Voice transcription (optional — requires `pip install -e .[voice]`)
WHISPER_ENABLED=false
WHISPER_MODEL=base

# Runtime
TZ=UTC
CHECK_INTERVAL_SECONDS=30
DEFAULT_SNOOZE_MINUTES=30

# Web Server
WEB_HOST=0.0.0.0
WEB_PORT=5005
# IMPORTANT: Generate a strong random secret key for production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_long_random_string_here

# Notion (optional)
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_TITLE_PROPERTY=Name

# Obsidian (optional - not recommended for production)
OBSIDIAN_VAULT_PATH=
OBSIDIAN_JOURNAL_RELATIVE=Journal/inbox.md

# MCP Server
MCP_CHAT_ID=0

# PostgreSQL password for docker-compose
POSTGRES_PASSWORD=your_secure_password_here
