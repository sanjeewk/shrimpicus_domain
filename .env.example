DISCORD_BOT_TOKEN=PASTE_YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_COMMAND_PREFIX=!

# Comma-separated list of channel names where every non-prefixed message
# is treated as directed at Shrimpicus (no @-mention required).
ASSISTANT_CHANNELS=general

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# LLM Provider: "ollama" (local) or "openrouter" (hosted)
# Use "openrouter" for faster, affordable API-based inference
LLM_PROVIDER=ollama

# OpenRouter API (only needed if LLM_PROVIDER=openrouter)
# Get free API key from: https://openrouter.ai
# Sign up gives you $1 free credit to start
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Available models on OpenRouter (with approximate costs for 100 queries/day):
# - meta-llama/llama-3.1-8b-instruct:free  ($0/month - FREE tier)
# - openai/gpt-4o-mini                     ($0.59/month - Best overall)
# - google/gemini-flash-1.5                ($0.29/month - Best value)
# - anthropic/claude-3.5-haiku             ($3.60/month - Best quality)
# - meta-llama/llama-3.1-70b-instruct      ($1.36/month - Best open-source)

# Voice transcription (optional — requires `pip install -e .[voice]`)
WHISPER_ENABLED=true
WHISPER_MODEL=base

# Runtime
TZ=UTC
DB_PATH=./data/shrimpicus.db
CHECK_INTERVAL_SECONDS=30
DEFAULT_SNOOZE_MINUTES=30

# Notion (optional)
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_TITLE_PROPERTY=Name

# Obsidian (optional)
OBSIDIAN_VAULT_PATH=
OBSIDIAN_JOURNAL_RELATIVE=Journal/inbox.md
